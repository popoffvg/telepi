{
  "name": "telepi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist artifacts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "package:release": "npm run build:clean && node scripts/package-release.mjs",
    "ci:release": "npm test && npm run package:release",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "grammy": "^1.35.0"
  },
  "optionalDependencies": {
    "parakeet-coreml": "^2.2.0",
    "sherpa-onnx-node": "1.12.32"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
