# telepi setup copies this file to ~/.config/telepi/config.env in installed mode.
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Replace 123456789 with your Telegram user ID(s), comma-separated if needed.
TELEGRAM_ALLOWED_USER_IDS=123456789

# Recommended in installed mode so fresh /new sessions start in the right project.
# Replace with an absolute path to the project you want new Telegram sessions to start in.
# TELEPI_WORKSPACE=/absolute/path/to/your/main/project

# TOOL_VERBOSITY=summary   # all | summary | errors-only | none (default: summary)

# Optional: enable cloud-based voice transcription via OpenAI Whisper (~$0.006/min)
# OPENAI_API_KEY=sk-...

# Optional: enable local/offline transcription via Sherpa-ONNX Parakeet
# (primarily for Intel-based Macs, where parakeet-coreml is not supported)
# SHERPA_ONNX_MODEL_DIR=/absolute/path/to/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8
# SHERPA_ONNX_NUM_THREADS=2

# Optional: open a specific Pi session file for hand-off
# /handoff usually injects this automatically.
# PI_SESSION_PATH=/home/telepi/.pi/agent/sessions/--Users--youruser--myproject--/2026-03-18_abc123.jsonl

# Optional: override model (e.g. anthropic/claude-sonnet-4-5)
# PI_MODEL=
