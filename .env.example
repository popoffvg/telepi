TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_USER_IDS=123456789

# TOOL_VERBOSITY=summary   # all | summary | errors-only | none (default: summary)

# Skills mode: controls which Pi skills are loaded into TelePi sessions.
# Default is "none" — safest for remote use (skills may depend on local CLI tools).
# PI_SKILLS=none            # none | all | skill1,skill2 (comma-separated allowlist)

# Optional: enable cloud-based voice transcription via OpenAI Whisper (~$0.006/min)
# OPENAI_API_KEY=sk-...

# Optional: open a specific Pi session file for hand-off
# PI_SESSION_PATH=/home/telepi/.pi/agent/sessions/--Users--youruser--myproject--/2026-03-18_abc123.jsonl

# Optional: override model (e.g. anthropic/claude-sonnet-4-5)
# PI_MODEL=
